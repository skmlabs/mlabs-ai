# ============================================================================
# mlabs-ai environment variables
# Copy to .env.local (dev) and set in Vercel project settings (prod).
# ============================================================================

# --- Supabase (DB + Auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Encryption for OAuth refresh tokens at rest ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# DO NOT rotate without a migration — old encrypted tokens won't decrypt.
ENCRYPTION_KEY=

# --- Google OAuth (Supabase Auth + GMB connection flow) ---
GOOGLE_OAUTH_CLIENT_ID=CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# --- Google Maps (for Places API / reviews) ---
GOOGLE_MAPS_API_KEY=AIza...

# --- App public URL ---
# Local: http://localhost:3000
# Prod:  https://app.mlabsdigital.org
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cron secret (Phase 5A.6) ---
# Used by /api/cron/sync-all and /api/gmb/reviews/sync-full (internal callers).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# In Vercel project settings: also set as the cron secret on the cron job.
CRON_SECRET=
